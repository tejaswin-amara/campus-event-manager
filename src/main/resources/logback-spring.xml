<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- ── Dev / Default: human-readable console output ── -->
    <springProfile name="!prod">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
            </encoder>
        </appender>

        <root level="INFO">
            <appender-ref ref="CONSOLE" />
        </root>
    </springProfile>

    <!-- ── Production: structured JSON for log aggregation ── -->
    <springProfile name="prod">
        <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <includeMdcKeyName>event_type</includeMdcKeyName>
                <includeMdcKeyName>login_user</includeMdcKeyName>
                <includeMdcKeyName>login_success</includeMdcKeyName>
                <includeMdcKeyName>client_ip</includeMdcKeyName>
                <includeMdcKeyName>user_agent</includeMdcKeyName>
                <includeMdcKeyName>upload_user</includeMdcKeyName>
                <includeMdcKeyName>file_name</includeMdcKeyName>
                <includeMdcKeyName>file_size</includeMdcKeyName>
                <includeMdcKeyName>upload_result</includeMdcKeyName>
            </encoder>
        </appender>

        <!-- Dedicated SECURITY_AUDIT logger for auth, upload, and admin actions -->
        <logger name="com.tejaswin.campus.security" level="INFO" additivity="true" />
        <logger name="SECURITY_AUDIT" level="INFO" additivity="false">
            <appender-ref ref="JSON_CONSOLE" />
        </logger>

        <root level="INFO">
            <appender-ref ref="JSON_CONSOLE" />
        </root>
    </springProfile>

</configuration>
